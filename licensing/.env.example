# Port the activation server listens on
PORT=4100

# Required. Long random string — protects the license-creation/admin API.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# How many days a client can keep working offline on a cached, signed token
# before it must successfully re-check in with the server.
OLI_LICENSE_OFFLINE_GRACE_DAYS=14

# Default device cap for newly generated licenses (can be overridden per-license).
OLI_LICENSE_DEFAULT_MAX_DEVICES=5

# Where license/device data is persisted (a plain JSON file — fine at this scale).
OLI_LICENSE_DATA_DIR=./data
